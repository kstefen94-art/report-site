<script>
  const $ = (id)=>document.getElementById(id);
  const MONTHS = (window.__DATA_MONTHS__ || []).slice().sort();
  const STORE  = (window.__DATASTORE__ || {});
  let ACTIVE_TAB = "03팀원";
  let CAL_YM = MONTHS.length ? MONTHS[MONTHS.length-1] : "202601";

  const REGION_ORDER = [
    "서울1권역","서울2권역","서울3권역","서울4권역",
    "경기1권역","경기2권역","경기3권역",
    "인천권역","부산권역","대구권역","대전권역","광주권역","전주권역","강원권역",
    "영남1권역","영남2권역","충청권역"
  ];
  const regionRank = new Map(REGION_ORDER.map((v,i)=>[v,i]));
  function sortRegions(arr){
    return (arr||[]).slice().sort((a,b)=>{
      const ia = regionRank.has(a) ? regionRank.get(a) : 999;
      const ib = regionRank.has(b) ? regionRank.get(b) : 999;
      if(ia !== ib) return ia - ib;
      return String(a).localeCompare(String(b), "ko");
    });
  }
  function sortFields(arr){
    const order = ["종병분야","병원분야","성장"];
    const rank = new Map(order.map((v,i)=>[v,i]));
    return (arr||[]).slice().sort((a,b)=>{
      const ia = rank.has(a) ? rank.get(a) : 999;
      const ib = rank.has(b) ? rank.get(b) : 999;
      if(ia !== ib) return ia - ib;
      return String(a).localeCompare(String(b), "ko");
    });
  }

  function fillSelect(sel, arr, includeAll=true, allLabel="전체"){
    const items = includeAll ? [allLabel, ...(arr||[])] : (arr||[]);
    sel.innerHTML = items.map(v=>`<option value="${v}">${v}</option>`).join("");
  }
  function empKey(name, code){ return `${name||""} (${code||""})`; }
  function empCodeFromLabel(v){
    if(!v || v==="전체") return null;
    const m = String(v).match(/\((\d{7})\)\s*$/);
    return m ? m[1] : null;
  }
  function currentFilters(){
    return {
      region: $("region").value,
      team: $("team").value,
      field: $("field").value,
      empLabel: $("emp").value,
      empCode: empCodeFromLabel($("emp").value),
      q: $("search").value.trim().toLowerCase()
    };
  }

  function avgOf(nums){
    const xs = nums.filter(x => Number.isFinite(x));
    if(!xs.length) return null;
    return xs.reduce((s,x)=>s+x,0)/xs.length;
  }
  function setKPICombo(id, avgVal, lunchVal, dinnerVal){
    const el = $(id);
    const a = (avgVal==null||!Number.isFinite(avgVal)) ? "-" : avgVal.toFixed(2);
    const l = (lunchVal==null||!Number.isFinite(lunchVal)) ? "-" : Math.round(lunchVal).toLocaleString();
    const d = (dinnerVal==null||!Number.isFinite(dinnerVal)) ? "-" : Math.round(dinnerVal).toLocaleString();
    el.textContent = `${a} / ${l} / ${d}`;
  }
  function fieldModeOf(field){
    const s = String(field||"");
    if (s.includes("종병")) return "GH";
    if (s.includes("병원")) return "CL";
    if (s.includes("성장")) return "GR";
    return "ETC";
  }
  function fieldModeFromFilterValue(v){
    const s = String(v||"");
    if(s === "전체") return "ALL";
    if(s.includes("종병")) return "GH";
    if(s.includes("병원")) return "CL";
    if(s.includes("성장")) return "GR";
    return "ALL";
  }

  function buildMatrixForRole(role){
    const empMap = new Map();
    for(const ym of MONTHS){
      const rows = (STORE[ym] && STORE[ym].rows) ? STORE[ym].rows : [];
      for(const r of rows){
        if (String(r.role||"") !== role) continue;
        const code = String(r.empCode||"").trim();
        if(!code) continue;

        if(!empMap.has(code)){
          empMap.set(code, {
            region: r.region||"",
            team: r.team||"",
            field: r.field||"",
            empCode: code,
            empName: r.empName||"",
            role: r.role||"",
            months: {}
          });
        }
        empMap.get(code).months[ym] = {
          avg: Number(r.kpi?.avg ?? 0),
          lunch: Number(r.kpi?.lunch ?? 0),
          dinner: Number(r.kpi?.dinner ?? 0)
        };
      }
    }
    return Array.from(empMap.values());
  }

  function displayCell(v){
    if(!v) return "-";
    const a = Number.isFinite(v.avg) ? v.avg.toFixed(2) : "0.00";
    const l = Number.isFinite(v.lunch) ? Math.round(v.lunch).toLocaleString() : "0";
    const d = Number.isFinite(v.dinner) ? Math.round(v.dinner).toLocaleString() : "0";
    return `${a} / ${l} / ${d}`;
  }

  function computeOptionsForRole(role){
    const matrix = buildMatrixForRole(role);
    const regions = sortRegions(Array.from(new Set(matrix.map(x=>x.region).filter(Boolean))));

    const teamsByRegion = new Map();
    for(const r of matrix){
      if(!r.region || !r.team) continue;
      if(!teamsByRegion.has(r.region)) teamsByRegion.set(r.region, new Set());
      teamsByRegion.get(r.region).add(r.team);
    }

    const empsByRegionTeam = new Map();
    for(const r of matrix){
      const key = `${r.region}||${r.team}`;
      if(!empsByRegionTeam.has(key)) empsByRegionTeam.set(key, new Set());
      empsByRegionTeam.get(key).add(empKey(r.empName, r.empCode));
    }

    const fields = sortFields(Array.from(new Set(matrix.map(x=>x.field).filter(Boolean))));
    return {matrix, regions, teamsByRegion, empsByRegionTeam, fields};
  }

  let OPT = computeOptionsForRole(ACTIVE_TAB);

  function syncRegionOptions(){
    fillSelect($("region"), OPT.regions, true, "전체");
    if(!$("region").value) $("region").value = "전체";
  }
  function syncTeamOptions(){
    const region = $("region").value || "전체";
    let teams = [];
    if(region === "전체"){
      const s = new Set();
      for(const setV of OPT.teamsByRegion.values()){
        for(const t of setV) s.add(t);
      }
      teams = Array.from(s).sort((a,b)=>String(a).localeCompare(String(b),"ko"));
    } else {
      teams = Array.from(OPT.teamsByRegion.get(region) || []).sort((a,b)=>String(a).localeCompare(String(b),"ko"));
    }
    const prev = $("team").value;
    fillSelect($("team"), teams, true, "전체");
    $("team").value = (prev && teams.includes(prev)) ? prev : "전체";
  }
  function syncEmpOptions(){
    const region = $("region").value || "전체";
    const team = $("team").value || "전체";

    let emps = [];
    if(region === "전체" && team === "전체"){
      const s = new Set();
      for(const setV of OPT.empsByRegionTeam.values()){
        for(const e of setV) s.add(e);
      }
      emps = Array.from(s).sort((a,b)=>String(a).localeCompare(String(b),"ko"));
    } else if(region !== "전체" && team === "전체"){
      const s = new Set();
      for(const [key,setV] of OPT.empsByRegionTeam.entries()){
        if(key.startsWith(region+"||")){
          for(const e of setV) s.add(e);
        }
      }
      emps = Array.from(s).sort((a,b)=>String(a).localeCompare(String(b),"ko"));
    } else {
      emps = Array.from(OPT.empsByRegionTeam.get(`${region}||${team}`) || []).sort((a,b)=>String(a).localeCompare(String(b),"ko"));
    }

    const prev = $("emp").value;
    fillSelect($("emp"), emps, true, "전체");
    $("emp").value = (prev && emps.includes(prev)) ? prev : "전체";
  }
  function syncFieldOptions(){
    fillSelect($("field"), OPT.fields, true, "전체");
    if(!$("field").value) $("field").value = "전체";
  }

  function initKpiYm(){
    fillSelect($("kpiYm"), MONTHS, true, "전체");
    $("kpiYm").value = "전체";
  }

  function collectKpi(kind, role, scope, ymSel, fieldMode){
    const nums = [];
    const monthsToUse = (ymSel && ymSel !== "전체") ? [ymSel] : MONTHS;

    for(const ym of monthsToUse){
      const rows = (STORE[ym] && STORE[ym].rows) ? STORE[ym].rows : [];
      for(const r of rows){
        if(String(r.role||"") !== role) continue;

        if(scope.region && String(r.region||"") !== scope.region) continue;
        if(scope.team && String(r.team||"") !== scope.team) continue;
        if(scope.empCode && String(r.empCode||"") !== scope.empCode) continue;

        if(fieldMode && fieldMode !== "ALL"){
          const fm = fieldModeOf(r.field);
          if(fieldMode === "GH" && fm !== "GH") continue;
          if(fieldMode === "CL" && fm !== "CL") continue;
          if(fieldMode === "GR" && fm !== "GR") continue;
        }

        let v = 0;
        if(kind === "avg") v = Number(r.kpi?.avg ?? 0);
        else v = Number((r.kpi && r.kpi[kind]) ?? 0);

        if(Number.isFinite(v)) nums.push(v);
      }
    }
    return nums;
  }

  function renderLeftKPIs(){
    const f = currentFilters();
    const ymSel = ($("kpiYm") && $("kpiYm").value) ? $("kpiYm").value : "전체";
    const role = ACTIVE_TAB;

    $("kpi_lbl_all").textContent = `${role} 전체 평균 (콜/중식/석식)`;
    const baseScope = { empCode: f.empCode || null };

    setKPICombo("kpi_all",
      avgOf(collectKpi("avg", role, baseScope, ymSel, "ALL")),
      avgOf(collectKpi("lunch", role, baseScope, ymSel, "ALL")),
      avgOf(collectKpi("dinner", role, baseScope, ymSel, "ALL")),
    );
    setKPICombo("kpi_gh",
      avgOf(collectKpi("avg", role, baseScope, ymSel, "GH")),
      avgOf(collectKpi("lunch", role, baseScope, ymSel, "GH")),
      avgOf(collectKpi("dinner", role, baseScope, ymSel, "GH")),
    );
    setKPICombo("kpi_cl",
      avgOf(collectKpi("avg", role, baseScope, ymSel, "CL")),
      avgOf(collectKpi("lunch", role, baseScope, ymSel, "CL")),
      avgOf(collectKpi("dinner", role, baseScope, ymSel, "CL")),
    );
    setKPICombo("kpi_gr",
      avgOf(collectKpi("avg", role, baseScope, ymSel, "GR")),
      avgOf(collectKpi("lunch", role, baseScope, ymSel, "GR")),
      avgOf(collectKpi("dinner", role, baseScope, ymSel, "GR")),
    );

    const regionScope = (f.region && f.region !== "전체") ? f.region : null;
    const teamScope   = (f.team && f.team !== "전체") ? f.team : null;

    // =========================================================
    // ✅ [수정 포인트 1]
    // 리포트 요약 "선택 권역/부과 평균"은 '팀 평균'이 되어야 하므로
    // emp(인원) 필터를 무시하고 계산 (팀 평균이 팀 평균으로 유지)
    // + field(분야) 필터도 동일하게 반영해서 오른쪽 상단 팀 평균과 값 일치
    // =========================================================
    const fieldMode = fieldModeFromFilterValue(f.field);

    if(!regionScope) setKPICombo("kpi_region", null, null, null);
    else {
      const scope = { region: regionScope }; // ✅ empCode 제거
      setKPICombo("kpi_region",
        avgOf(collectKpi("avg", role, scope, ymSel, fieldMode)),
        avgOf(collectKpi("lunch", role, scope, ymSel, fieldMode)),
        avgOf(collectKpi("dinner", role, scope, ymSel, fieldMode)),
      );
    }

    if(!teamScope) setKPICombo("kpi_team", null, null, null);
    else {
      const scope = { team: teamScope }; // ✅ empCode 제거
      if(regionScope) scope.region = regionScope; // ✅ 권역 선택시 팀 중복 방지
      setKPICombo("kpi_team",
        avgOf(collectKpi("avg", role, scope, ymSel, fieldMode)),
        avgOf(collectKpi("lunch", role, scope, ymSel, fieldMode)),
        avgOf(collectKpi("dinner", role, scope, ymSel, fieldMode)),
      );
    }
  }

  function isCalendarVisible(){
    return $("calendarView").style.display !== "none";
  }
  function currentTopKpiMonth(){
    if(isCalendarVisible()) return CAL_YM;
    const ymSel = ($("kpiYm") && $("kpiYm").value) ? $("kpiYm").value : "전체";
    return ymSel;
  }
  function setScopeCard(valId, subId, label, combo, subText){
    $(valId).textContent = combo ?? "-";
    $(subId).textContent = subText ?? "-";
  }
  function fmtCombo(avgVal, lunchVal, dinnerVal){
    const a = (avgVal==null||!Number.isFinite(avgVal)) ? "-" : avgVal.toFixed(2);
    const l = (lunchVal==null||!Number.isFinite(lunchVal)) ? "-" : Math.round(lunchVal).toLocaleString();
    const d = (dinnerVal==null||!Number.isFinite(dinnerVal)) ? "-" : Math.round(dinnerVal).toLocaleString();
    return `${a} / ${l} / ${d}`;
  }
  function renderTopScopeKPIs(){
    const f = currentFilters();
    const role = ACTIVE_TAB;
    const ymSel = currentTopKpiMonth();
    const fieldMode = fieldModeFromFilterValue(f.field);

    if(f.region && f.region !== "전체"){
      const scope = { region: f.region };
      const a = avgOf(collectKpi("avg", role, scope, ymSel, fieldMode));
      const l = avgOf(collectKpi("lunch", role, scope, ymSel, fieldMode));
      const d = avgOf(collectKpi("dinner", role, scope, ymSel, fieldMode));
      setScopeCard("sk_region","sk_region_sub","권역", fmtCombo(a,l,d), `${f.region} · ${ymSel}`);
    } else {
      setScopeCard("sk_region","sk_region_sub","권역", "-", "권역 미선택");
    }

    if(f.team && f.team !== "전체"){
      const scope = { team: f.team };
      if(f.region && f.region !== "전체") scope.region = f.region;
      const a = avgOf(collectKpi("avg", role, scope, ymSel, fieldMode));
      const l = avgOf(collectKpi("lunch", role, scope, ymSel, fieldMode));
      const d = avgOf(collectKpi("dinner", role, scope, ymSel, fieldMode));
      const sub = (f.region && f.region !== "전체") ? `${f.region} / ${f.team} · ${ymSel}` : `${f.team} · ${ymSel}`;
      setScopeCard("sk_team","sk_team_sub","팀", fmtCombo(a,l,d), sub);
    } else {
      setScopeCard("sk_team","sk_team_sub","팀", "-", "팀 미선택");
    }

    if(f.empCode){
      const scope = { empCode: f.empCode };
      const a = avgOf(collectKpi("avg", role, scope, ymSel, fieldMode));
      const l = avgOf(collectKpi("lunch", role, scope, ymSel, fieldMode));
      const d = avgOf(collectKpi("dinner", role, scope, ymSel, fieldMode));
      setScopeCard("sk_emp","sk_emp_sub","인원", fmtCombo(a,l,d), `${f.empLabel} · ${ymSel}`);
    } else {
      setScopeCard("sk_emp","sk_emp_sub","인원", "-", "인원 미선택");
    }
  }

  function renderTable(){
    const thead = $("theadRow");
    const tbody = document.querySelector("#tbl tbody");
    thead.innerHTML = "";
    tbody.innerHTML = "";

    const f = currentFilters();
    const empCode = f.empCode;

    let matrix = buildMatrixForRole(ACTIVE_TAB);

    if(f.region!=="전체") matrix = matrix.filter(r=>r.region===f.region);
    if(f.team!=="전체") matrix = matrix.filter(r=>r.team===f.team);
    if(f.field!=="전체") matrix = matrix.filter(r=>r.field===f.field);
    if(empCode) matrix = matrix.filter(r=>r.empCode===empCode);

    if(f.q){
      const q = f.q;
      matrix = matrix.filter(r=>{
        const name  = String(r.empName||"").toLowerCase();
        const code  = String(r.empCode||"").toLowerCase();
        const region= String(r.region||"").toLowerCase();
        const team  = String(r.team||"").toLowerCase();
        const field = String(r.field||"").toLowerCase();
        return name.includes(q) || code.includes(q) || region.includes(q) || team.includes(q) || field.includes(q);
      });
    }

    $("topSub").textContent = `표시 월: ${MONTHS.length}개`;
    $("leftSub").textContent = `표시 월: ${MONTHS.join(", ")}`;
    $("mainSub").textContent = `${f.region} / ${f.team} / ${f.empLabel} / ${f.field} / ${ACTIVE_TAB}`;

    const baseCols = ["권역명","부과명2","분야","사원코드","사원명","직책"];
    baseCols.forEach(lbl=>{
      const th = document.createElement("th");
      th.textContent = lbl;
      thead.appendChild(th);
    });

    MONTHS.forEach(ym=>{
      const th = document.createElement("th");
      th.innerHTML = `<div style="font-weight:900;">${ym}</div>
                      <div style="margin-top:2px;font-size:11px;color:var(--muted);font-weight:800;">
                        평균콜수 / 중식횟수 / 석식횟수
                      </div>`;
      thead.appendChild(th);
    });

    for(const r of matrix){
      const tr = document.createElement("tr");
      const cells = [
        `<td class="left">${r.region||""}</td>`,
        `<td class="left">${r.team||""}</td>`,
        `<td>${r.field||""}</td>`,
        `<td>${r.empCode||""}</td>`,
        `<td class="left">${r.empName||""}</td>`,
        `<td>${r.role||""}</td>`
      ];
      for(const ym of MONTHS){
        cells.push(`<td class="center num">${displayCell(r.months[ym])}</td>`);
      }
      tr.innerHTML = cells.join("");
      tbody.appendChild(tr);
    }

    renderLeftKPIs();
    renderTopScopeKPIs();
  }

  // ===== Calendar =====
  function ymToParts(ym){
    const y = Number(String(ym).slice(0,4));
    const m = Number(String(ym).slice(4,6)) - 1;
    return {y,m};
  }
  function isWeekday(dateStr){
    const parts = String(dateStr||"").split("-");
    if(parts.length !== 3) return true;
    const y = Number(parts[0]), m = Number(parts[1])-1, d = Number(parts[2]);
    const dt = new Date(y,m,d);
    const dow = dt.getDay();
    return dow !== 0 && dow !== 6;
  }

  function fmtEventLine(e){
    const t = String(e.type||"");
    if(t === "CALL"){
      const acc = String(e.account||"").trim();
      const hcp = String(e.person||"").trim();
      const item = String(e.item||"").trim();
      return `${acc}${hcp ? " - " + hcp : ""}${item ? "(" + item + ")" : ""}`.trim();
    }
    if(t === "SM"){
      // =========================================================
      // ✅ [수정 포인트 2]
      // SM 이벤트에서 거래처(괄호) 제거: 고객-품목(구분명 구분)
      // (고객이 비어있을 때만 안전하게 거래처를 대체값으로 사용)
      // =========================================================
      const cust = String(e.person||"").trim();
      const acc  = String(e.account||"").trim();
      const item = String(e.item||"").trim();
      const kindName = String(e.kindName||"").trim();
      const kind = String(e.kind||"").trim();

      let left = cust;
      if(!left) left = acc; // fallback only
      const sub = `${kindName}${kind ? " " + kind : ""}`.trim();
      return `${left}-${item}${sub ? "(" + sub + ")" : ""}`.trim();
    }
    return "-";
  }

  function getFilteredEvents(ym){
    const f = currentFilters();
    const pack = STORE[ym] || {};
    const events = (pack.events || []).slice();
    const type = $("calType").value || "ALL";

    return events.filter(e=>{
      if(String(e.role||"") !== ACTIVE_TAB) return false;

      if(f.region!=="전체" && String(e.region||"") !== f.region) return false;
      if(f.team!=="전체" && String(e.team||"") !== f.team) return false;
      if(f.field!=="전체" && String(e.field||"") !== f.field) return false;
      if(f.empCode && String(e.empCode||"") !== f.empCode) return false;

      if(type!=="ALL" && String(e.type||"") !== type) return false;

      if(f.q){
        const q = f.q;
        const line = fmtEventLine(e).toLowerCase();
        const empN = String(e.empName||"").toLowerCase();
        const empC = String(e.empCode||"").toLowerCase();
        const region= String(e.region||"").toLowerCase();
        const team= String(e.team||"").toLowerCase();
        const field= String(e.field||"").toLowerCase();
        if(!line.includes(q) && !empN.includes(q) && !empC.includes(q) && !region.includes(q) && !team.includes(q) && !field.includes(q)) return false;
      }
      return true;
    });
  }

  function groupByDate(events){
    const map = new Map();
    for(const e of events){
      const d = String(e.date||"");
      if(!d) continue;
      if(!isWeekday(d)) continue;
      if(!map.has(d)) map.set(d, []);
      map.get(d).push(e);
    }

    for(const [k,arr] of map.entries()){
      arr.sort((a,b)=>{
        const rank = (t)=> (t==="SM" ? 0 : (t==="CALL" ? 1 : 9));
        const ra = rank(String(a.type||""));
        const rb = rank(String(b.type||""));
        if(ra !== rb) return ra - rb;
        return String(a.item||"").localeCompare(String(b.item||""), "ko");
      });
    }

    return map;
  }

  function openModal(title, items){
    $("modalTitle").textContent = title;
    const list = $("modalList");
    list.innerHTML = "";
    for(const e of items){
      const line = fmtEventLine(e);
      const sub = `${e.empName||""}(${e.empCode||""}) · ${e.region||""}/${e.team||""}/${e.field||""}`;
      const card = document.createElement("div");
      card.className = (String(e.type)==="SM") ? "evtCard sm" : "evtCard";
      card.innerHTML = `<div class="evtTitle">[${e.type}] ${line}</div><div class="evtSub">${sub}</div>`;
      list.appendChild(card);
    }
    $("modalBg").style.display = "flex";
  }
  function closeModal(){ $("modalBg").style.display = "none"; }
  $("modalClose").addEventListener("click", closeModal);
  $("modalBg").addEventListener("click", (ev)=>{ if(ev.target.id==="modalBg") closeModal(); });

  function renderCalendarSummary(filteredEvents){
    const map = new Map();

    for(const e of filteredEvents){
      const d = String(e.date||"");
      if(!d || !isWeekday(d)) continue;

      const item = String(e.item||"").trim();
      if(!item) continue;

      if(!map.has(item)) map.set(item, {call:0, lunch:0, dinner:0});
      const rec = map.get(item);

      if(String(e.type)==="CALL"){
        rec.call += 1;
      } else if(String(e.type)==="SM"){
        const kind = String(e.kind||"").trim();
        if(kind === "석식") rec.dinner += 1;
        else if(kind === "중식" || kind === "조식") rec.lunch += 1;
        else rec.lunch += 1;
      }
    }

    const rows = Array.from(map.entries())
      .map(([item, v])=>({item, ...v, total: v.call+v.lunch+v.dinner}))
      .sort((a,b)=> b.total - a.total || b.call - a.call || a.item.localeCompare(b.item,"ko"));

    let totalCall=0, totalLunch=0, totalDinner=0;
    for(const r of rows){
      totalCall += r.call; totalLunch += r.lunch; totalDinner += r.dinner;
    }

    const f = currentFilters();
    const calType = $("calType").value || "ALL";
    $("calSumSub").textContent =
      `월:${CAL_YM} · 탭:${ACTIVE_TAB} · 타입:${calType} · ${f.region}/${f.team}/${f.empLabel}/${f.field}` +
      (f.q ? ` · 검색:"${f.q}"` : "");

    if(!rows.length){
      $("calSumTable").innerHTML = `<div style="padding:10px; color:var(--muted); font-size:12px;">표시할 품목 집계가 없습니다.</div>`;
      return;
    }

    const top = rows.slice(0, 50);

    const tableHtml = `
      <table>
        <colgroup>
          <col style="width:58%">
          <col style="width:14%">
          <col style="width:14%">
          <col style="width:14%">
        </colgroup>
        <thead>
          <tr>
            <th>품목</th>
            <th>콜수</th>
            <th>중식</th>
            <th>석식</th>
          </tr>
        </thead>
        <tbody>
          <tr style="font-weight:900;">
            <td>합계</td>
            <td>${totalCall.toLocaleString()}</td>
            <td>${totalLunch.toLocaleString()}</td>
            <td>${totalDinner.toLocaleString()}</td>
          </tr>
          ${top.map(r=>`
            <tr>
              <td title="${String(r.item||"").replaceAll('"','&quot;')}">${r.item}</td>
              <td>${r.call.toLocaleString()}</td>
              <td>${r.lunch.toLocaleString()}</td>
              <td>${r.dinner.toLocaleString()}</td>
            </tr>
          `).join("")}
        </tbody>
      </table>
    `;
    $("calSumTable").innerHTML = tableHtml;
  }

  function renderCalendar(){
    const pack = STORE[CAL_YM] || {};
    const warn = $("calWarn");
    const totalEvents = (pack.events || []).length;

    if(totalEvents === 0){
      warn.style.display = "";
      warn.textContent = `⚠ ${CAL_YM} events가 0건입니다. (JSON 생성에서 이벤트가 생성되지 않았을 가능성)`;
    } else {
      warn.style.display = "none";
      warn.textContent = "";
    }

    const {y, m} = ymToParts(CAL_YM);
    $("calSub").textContent = `월: ${CAL_YM} · (월~금) 칸당 최대 20개 표시(초과는 더보기/클릭)`;

    const filtered = getFilteredEvents(CAL_YM);
    renderCalendarSummary(filtered);

    const byDate = groupByDate(filtered);

    const firstDay = new Date(y, m, 1);
    const lastDay  = new Date(y, m + 1, 0);
    const days = lastDay.getDate();

    let html = "";

    const dows = ["월","화","수","목","금"];
    for(const d of dows){
      html += `<div class="calDow">${d}</div>`;
    }

    let offset = 0;
    const startDow = firstDay.getDay();
    if (startDow >= 1 && startDow <= 5) offset = startDow - 1;
    else offset = 0;

    for(let i=0;i<offset;i++){
      html += `<div></div>`;
    }

    for(let day=1; day<=days; day++){
      const dt = new Date(y, m, day);
      const dow = dt.getDay();
      if(dow === 0 || dow === 6) continue;

      const dateStr = `${y}-${String(m+1).padStart(2,"0")}-${String(day).padStart(2,"0")}`;
      const items = byDate.get(dateStr) || [];
      const cnt = items.length;

      const preview = items.slice(0,20).map(e=>{
        const tag = (e.type === "CALL") ? "CALL" : "SM";
        const line = fmtEventLine(e);
        const cls = (String(e.type)==="SM") ? "evtMini sm" : "evtMini";
        return `<div class="${cls}" title="${line.replaceAll('"','&quot;')}"><span class="t">${tag}</span>${line}</div>`;
      }).join("");

      const more = (cnt > 20)
        ? `<button class="moreBtn" data-date="${dateStr}">더보기 (+${cnt-20})</button>`
        : "";

      html += `
        <div class="calCell" data-date="${dateStr}">
          <div class="calDayLine">
            <div class="calDay">${day}</div>
            <div class="calCnt">${cnt ? `${cnt}건<span class="chip">표시 20</span>` : ""}</div>
          </div>
          <div class="evtBox">${preview || `<div class="evtMini" style="color:var(--muted);">-</div>`}</div>
          ${more}
        </div>
      `;
    }

    $("calGrid").innerHTML = html;

    document.querySelectorAll(".moreBtn").forEach(btn=>{
      btn.addEventListener("click", (ev)=>{
        ev.stopPropagation();
        const dateStr = btn.dataset.date;
        const full = byDate.get(dateStr) || [];
        openModal(`${dateStr} (${full.length}건)`, full);
      });
    });

    document.querySelectorAll(".calCell").forEach(cell=>{
      cell.addEventListener("click", ()=>{
        const dateStr = cell.dataset.date;
        const full = byDate.get(dateStr) || [];
        if(full.length) openModal(`${dateStr} (${full.length}건)`, full);
      });
    });

    renderTopScopeKPIs();
  }

  function syncCalendarMonthOptions(){
    fillSelect($("calYm"), MONTHS, false, "");
    $("calYm").value = CAL_YM;
  }

  function showCalendar(){
    $("reportView").style.display = "none";
    $("calendarView").style.display = "block";
    $("calBtn").style.display = "none";
    $("backBtn").style.display = "inline-block";
    syncCalendarMonthOptions();
    renderCalendar();
  }
  function showReport(){
    $("reportView").style.display = "grid";
    $("calendarView").style.display = "none";
    $("calBtn").style.display = "inline-block";
    $("backBtn").style.display = "none";
    renderTopScopeKPIs();
  }

  function initAllFilters(){
    OPT = computeOptionsForRole(ACTIVE_TAB);
    syncRegionOptions();
    syncTeamOptions();
    syncEmpOptions();
    syncFieldOptions();

    $("region").value = "전체";
    $("team").value = "전체";
    $("emp").value = "전체";
    $("field").value = "전체";
  }

  function handleRegionChange(){
    syncTeamOptions();
    syncEmpOptions();
    renderTable();
    if($("calendarView").style.display !== "none") renderCalendar();
    else renderTopScopeKPIs();
  }
  function handleTeamChange(){
    syncEmpOptions();
    renderTable();
    if($("calendarView").style.display !== "none") renderCalendar();
    else renderTopScopeKPIs();
  }
  function handleEmpChange(){
    renderTable();
    if($("calendarView").style.display !== "none") renderCalendar();
    else renderTopScopeKPIs();
  }

  function initResizableSidePanel(){
    const side = $("calSide");
    if(!side) return;

    const minW = 260, maxW = 780, defW = 360;
    const saved = localStorage.getItem("calSideWidth");
    if(saved){
      let w = parseInt(saved, 10);
      if(Number.isFinite(w)){
        w = Math.max(minW, Math.min(maxW, w));
        side.style.width = `${w}px`;
      }
    }

    const saveWidth = ()=>{
      const w = Math.round(side.getBoundingClientRect().width);
      if(Number.isFinite(w)){
        const ww = Math.max(minW, Math.min(maxW, w));
        localStorage.setItem("calSideWidth", String(ww));
      }
    };
    window.addEventListener("mouseup", saveWidth);
    window.addEventListener("touchend", saveWidth);

    side.addEventListener("dblclick", ()=>{
      side.style.width = `${defW}px`;
      localStorage.removeItem("calSideWidth");
    });
  }

  function init(){
    document.querySelectorAll(".tab").forEach(btn=>{
      btn.addEventListener("click", ()=>{
        document.querySelectorAll(".tab").forEach(x=>x.classList.remove("active"));
        btn.classList.add("active");
        ACTIVE_TAB = btn.dataset.tab;

        initAllFilters();
        renderTable();
        if($("calendarView").style.display !== "none") renderCalendar();
      });
    });

    initAllFilters();
    initKpiYm();
    initResizableSidePanel();

    $("region").addEventListener("change", handleRegionChange);
    $("team").addEventListener("change", handleTeamChange);
    $("emp").addEventListener("change", handleEmpChange);
    $("field").addEventListener("change", ()=>{
      renderTable();
      if($("calendarView").style.display !== "none") renderCalendar();
      else renderTopScopeKPIs();
    });
    $("search").addEventListener("input", ()=>{
      renderTable();
      if($("calendarView").style.display !== "none") renderCalendar();
    });

    $("kpiYm").addEventListener("change", ()=>{
      renderLeftKPIs();
      renderTopScopeKPIs();
    });

    $("calBtn").addEventListener("click", showCalendar);
    $("backBtn").addEventListener("click", showReport);

    $("calYm").addEventListener("change", ()=>{
      CAL_YM = $("calYm").value;
      renderCalendar();
    });
    $("calType").addEventListener("change", renderCalendar);

    renderTable();
    renderTopScopeKPIs();
  }

  init();
</script>
</body>
