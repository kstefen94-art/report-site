def load_months(data_dir: Path):
    store = {}
    months = []
    for p in sorted(data_dir.glob("20????.json")):
        ym = p.stem
        store[ym] = json.loads(p.read_text(encoding="utf-8"))
        months.append(ym)
    return sorted(months), store


