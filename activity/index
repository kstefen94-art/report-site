# 4) 월 JSON 생성
# =========================================================
def build_month_json(ym: str, master_path: Path, call_path: Path, act_path: Path) -> dict:
    master = load_txt(master_path)
    master.columns = [c.strip() for c in master.columns]

    if "권역코드" not in master.columns and "권코드" in master.columns:
        master = master.rename(columns={"권코드": "권역코드"})

    if "사원코드1" in master.columns:
        emp_col = "사원코드1"
    elif "사원코드2" in master.columns:
        emp_col = "사원코드2"
    else:
        raise ValueError(f"{ym} MASTER에 사원코드1/2가 없습니다: {list(master.columns)}")

    need_master = {"권역코드", "권역명", "부과코드", "부과명2", "분야", "사원명", "직책"}
    miss_m = need_master - set(master.columns)
    if miss_m:
        raise ValueError(f"{ym} MASTER 필수 컬럼 누락: {miss_m}")

    m = master.copy().rename(columns={emp_col: "사번"})
    for col in ["사번", "부과코드", "직책", "분야", "권역코드", "권역명", "부과명2", "사원명"]:
        m[col] = m[col].astype(str).str.strip()

    m = m[m["직책"].isin(KEEP_ROLES)].copy()
    m = m[~m["부과코드"].str.endswith("00", na=False)].copy()
    m["fieldType"] = m["분야"].apply(normalize_field_type)

    m = m.drop_duplicates(subset=["사번"], keep="first")

    act = load_activity(act_path)
    m = m.merge(act, on="사번", how="left")
    m["활동일수"] = pd.to_numeric(m["활동일수"], errors="coerce").fillna(0)

    meal_counts, sm_events = load_sm_meal_counts_and_events(ym, m)
    m = m.merge(meal_counts, on="사번", how="left")
    m["lunch"] = pd.to_numeric(m.get("lunch", 0), errors="coerce").fillna(0).astype(int)
    m["dinner"] = pd.to_numeric(m.get("dinner", 0), errors="coerce").fillna(0).astype(int)

    call_counts, call_events = load_call_counts_and_events(ym, call_path, m)
    out = m.merge(call_counts, on="사번", how="left")
    out["total_calls_owner"] = pd.to_numeric(out.get("total_calls_owner", 0), errors="coerce").fillna(0).astype(int)
    out["total_calls_all"] = pd.to_numeric(out.get("total_calls_all", 0), errors="coerce").fillna(0).astype(int)

    out["total_calls"] = 0
    m03 = out["직책"].eq("03팀원")
    m02 = out["직책"].eq("02팀장")
    out.loc[m03, "total_calls"] = out.loc[m03, "total_calls_owner"]
    out.loc[m02, "total_calls"] = out.loc[m02, "total_calls_all"]

    out[ym] = np.where(out["활동일수"] > 0, out["total_calls"] / out["활동일수"], 0.0)
    out[ym] = pd.to_numeric(out[ym], errors="coerce").fillna(0).round(2)

    rows = []
    for _, r in out.iterrows():
        rows.append({
            "ym": ym,
            "region": str(r["권역명"] or ""),
            "team": str(r["부과명2"] or ""),
            "field": str(r["분야"] or ""),
            "role": str(r["직책"] or ""),
            "empCode": str(r["사번"] or ""),
            "empName": str(r["사원명"] or ""),
            "kpi": {
                "avg": float(r[ym]),
                "lunch": int(r["lunch"]),
                "dinner": int(r["dinner"]),
            }
        })

    events = call_events + sm_events
    return {"rows": rows, "events": events}


def find_months(base_dir: Path):
    months = []
    for p in base_dir.iterdir():
        if p.is_file():
            m = YM_MASTER_RE.match(p.name)
            if m:
                months.append(m.group(1))
    return sorted(set(months))


def generate_all_months_json():
    months = find_months(BASE_DIR)
    if not months:
        print("MASTER 파일(YYYYMMMASTER.txt)을 찾지 못했습니다.")
        return

    made = 0
    for ym in months:
        master_path = BASE_DIR / f"{ym}MASTER.txt"
        call_path = BASE_DIR / f"{ym}CALL.txt"
        act_path = BASE_DIR / f"{ym}ACT.txt"

        if not call_path.exists() or not act_path.exists():
            print(f"[SKIP] {ym}: CALL 또는 ACT 파일이 없음")
            continue

        try:
            payload = build_month_json(ym, master_path, call_path, act_path)
            out_path = DATA_DIR / f"{ym}.json"
            out_path.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
            print(f"[OK] {ym} -> {out_path}")
            made += 1
        except Exception as e:
            print(f"[FAIL] {ym}: {e}")

    print(f"완료: {made}개 월 JSON 생성")


