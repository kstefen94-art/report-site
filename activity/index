# =========================================================
# 1) 공통 유틸
# =========================================================
def load_txt(path: Path) -> pd.DataFrame:
    if not path.exists():
        raise FileNotFoundError(f"파일을 찾을 수 없습니다: {path.resolve()}")

    # 1) 탭 우선
    try:
        df = pd.read_csv(path, sep="\t", encoding="utf-8-sig", dtype=str)
        if df.shape[1] > 1:
            return df
    except Exception:
        pass

    # 2) 자동 구분자
    return pd.read_csv(path, sep=None, engine="python", encoding="utf-8-sig", dtype=str)


def extract_emp_codes_from_text(x):
    if pd.isna(x):
        return []
    return EMP_CODE_PATTERN.findall(str(x))


def normalize_field_type(s: str) -> str:
    s = "" if pd.isna(s) else str(s)
    if "병원" in s:
        return "병원"
    if "종병" in s:
        return "종병"
    if "성장" in s:
        return "성장"
    return "기타"


def find_date_col(df: pd.DataFrame, candidates: list[str]) -> str | None:
    cols = [c.strip() for c in df.columns]
    df.columns = cols

    for c in candidates:
        if c in cols:
            return c
    for c in cols:
        if "일자" in c or c.endswith("일") or "date" in c.lower():
            return c
    return None


def to_yyyy_mm_dd(x) -> str | None:
    if pd.isna(x):
        return None
    s = str(x).strip()
    if not s or s.lower() in {"nan", "none"}:
        return None

    m = re.match(r"^(\d{4})(\d{2})(\d{2})$", s)
    if m:
        return f"{m.group(1)}-{m.group(2)}-{m.group(3)}"

    m = re.match(r"^(\d{4})-(\d{2})-(\d{2})$", s)
    if m:
        return s

    m = re.match(r"^(\d{4})/(\d{2})/(\d{2})$", s)
    if m:
        return f"{m.group(1)}-{m.group(2)}-{m.group(3)}"

    m = re.match(r"^(\d{4})\.(\d{2})\.(\d{2})$", s)
    if m:
        return f"{m.group(1)}-{m.group(2)}-{m.group(3)}"

    return None


def make_master_lookup(master_m: pd.DataFrame) -> dict:
    mm = master_m.copy()
    mm["사번"] = mm["사번"].astype(str).str.strip()
    mm = mm[mm["사번"] != ""].dropna(subset=["사번"])
    mm = mm.drop_duplicates(subset=["사번"], keep="first")
    return mm.set_index("사번").to_dict(orient="index")


def load_activity(path: Path) -> pd.DataFrame:
    df = load_txt(path)
    df.columns = [c.strip() for c in df.columns]

    if "사번" not in df.columns:
        for cand in ["사원코드", "사원코드1", "사원코드2"]:
            if cand in df.columns:
                df = df.rename(columns={cand: "사번"})
                break
    if "사번" not in df.columns:
        raise ValueError(f"ACT 파일에 사번 컬럼이 없습니다: {path.name} / {list(df.columns)}")

    days_col = None
    for c in df.columns:
        if "활동일수" in c:
            days_col = c
            break
    if not days_col:
        raise ValueError(f"ACT 파일에서 활동일수 컬럼을 못 찾았습니다: {path.name} / {list(df.columns)}")

    out = df.rename(columns={days_col: "활동일수"}).copy()
    out["사번"] = out["사번"].astype(str).str.strip()
    out["활동일수"] = pd.to_numeric(out["활동일수"], errors="coerce").fillna(0)
    return out[["사번", "활동일수"]]


# =========================================================
# 2) SM(식사) 카운트 + events
#    - SM 달력 표시: 고객(거래처)-품목(구분명 구분)
# =========================================================
def load_sm_meal_counts_and_events(ym: str, master_m: pd.DataFrame):
    sm_path = BASE_DIR / f"{ym}SM.txt"
    if not sm_path.exists():
        return pd.DataFrame(columns=["사번", "lunch", "dinner"]), []

    df = load_txt(sm_path)
    df.columns = [c.strip() for c in df.columns]

    if "고객코드" not in df.columns or "구분" not in df.columns:
        raise ValueError(f"[{ym}] SM 파일 컬럼 필요: 고객코드, 구분 / 현재: {list(df.columns)} / 파일: {sm_path.name}")

    date_col = find_date_col(df, SM_DATE_CANDIDATES)

    x = df.copy()
    x["고객코드"] = x["고객코드"].astype(str).str.strip()
    x["구분"] = x["구분"].astype(str).str.strip()

    x["mealType"] = x["구분"].map({"석식": "dinner", "조식": "lunch", "중식": "lunch"})
    x = x.dropna(subset=["고객코드", "mealType"])
    x = x[x["고객코드"] != ""]

    pivot = x.pivot_table(index="고객코드", columns="mealType", aggfunc="size", fill_value=0).reset_index()
    if "lunch" not in pivot.columns:
        pivot["lunch"] = 0
    if "dinner" not in pivot.columns:
        pivot["dinner"] = 0

    meal_counts = pivot.rename(columns={"고객코드": "사번"})[["사번", "lunch", "dinner"]].copy()
    meal_counts["사번"] = meal_counts["사번"].astype(str).str.strip()
    meal_counts["lunch"] = pd.to_numeric(meal_counts["lunch"], errors="coerce").fillna(0).astype(int)
    meal_counts["dinner"] = pd.to_numeric(meal_counts["dinner"], errors="coerce").fillna(0).astype(int)

    master_lookup = make_master_lookup(master_m)
    x["_date"] = x[date_col].apply(to_yyyy_mm_dd) if date_col else None

    acc_col = "거래처" if "거래처" in x.columns else ("거래처명" if "거래처명" in x.columns else None)
    cust_col = "고객" if "고객" in x.columns else ("고객명" if "고객명" in x.columns else None)
    item_col = "품목" if "품목" in x.columns else ("품목명" if "품목명" in x.columns else None)

    events = []
    for _, r in x.iterrows():
        emp = str(r["고객코드"]).strip()
        if emp not in master_lookup:
            continue
        d = r["_date"]
        if not d:
            continue
        info = master_lookup[emp]

        evt = {
            "date": d,
            "type": "SM",
            "empCode": emp,
            "empName": info.get("사원명", ""),
            "role": info.get("직책", ""),
            "region": info.get("권역명", ""),
            "team": info.get("부과명2", ""),
            "field": info.get("분야", ""),

            "account": str(r.get(acc_col, "") or "").strip() if acc_col else "",
            "person": str(r.get(cust_col, "") or "").strip() if cust_col else "",
            "item": str(r.get(item_col, "") or "").strip() if item_col else "",
            "kindName": str(r.get("구분명", "") or "").strip(),
            "kind": str(r.get("구분", "") or "").strip(),
        }
        events.append(evt)

    return meal_counts, events


# =========================================================
# 3) CALL 카운트 + events
# =========================================================
def load_call_counts_and_events(ym: str, call_path: Path, master_m: pd.DataFrame):
    call = load_txt(call_path)
    call.columns = [c.strip() for c in call.columns]

    need_min = {"담당자", "구분", "담당자분야", "방문일"}
    miss_min = need_min - set(call.columns)
    if miss_min:
        raise ValueError(f"{ym} CALL 최소 필수 컬럼 누락: {miss_min} / 현재: {list(call.columns)}")

    has_comp = "동행자" in call.columns
    date_col = find_date_col(call, CALL_DATE_CANDIDATES)

    c = call.copy()
    c["구분"] = c["구분"].astype(str).str.strip()
    c = c[c["구분"].ne("D2")].copy()  # ✅ D2만 제외

    c["담당자"] = c["담당자"].astype(str).str.strip()
    c["_date"] = c[date_col].apply(to_yyyy_mm_dd) if date_col else None

    owner_rows = c[["담당자"]].rename(columns={"담당자": "participant"}).copy()
    owner_rows["participant"] = owner_rows["participant"].astype(str).str.strip()

    all_rows = owner_rows.copy()
    if has_comp:
        comp = c[["동행자"]].copy()
        comp["participant"] = comp["동행자"].apply(extract_emp_codes_from_text)
        comp = comp.explode("participant")
        comp = comp[comp["participant"].notna() & (comp["participant"].astype(str).str.len() > 0)]
        comp["participant"] = comp["participant"].astype(str).str.strip()
        comp = comp[["participant"]]
        all_rows = pd.concat([all_rows, comp], ignore_index=True)

    cnt_owner_total = owner_rows.groupby("participant", dropna=False).size().rename("total_calls_owner").reset_index()
    cnt_all_total = all_rows.groupby("participant", dropna=False).size().rename("total_calls_all").reset_index()

    counts = cnt_owner_total.merge(cnt_all_total, on="participant", how="outer").fillna(0)
    counts["total_calls_owner"] = counts["total_calls_owner"].astype(int)
    counts["total_calls_all"] = counts["total_calls_all"].astype(int)
    counts = counts.rename(columns={"participant": "사번"})

    master_lookup = make_master_lookup(master_m)
    events = []

    for _, r in c.iterrows():
        d = r["_date"]
        if not d:
            continue

        participants = []
        owner_emp = str(r.get("담당자", "") or "").strip()
        if owner_emp:
            participants.append(owner_emp)
        if has_comp:
            participants.extend(extract_emp_codes_from_text(r.get("동행자", "")))
        participants = [p for p in dict.fromkeys(participants) if p]

        acc = str(r.get("거래처명", "") or "").strip()
        hcp = str(r.get("고객명", "") or "").strip()
        item = str(r.get("품목명", "") or "").strip()

        if not acc:
            acc = str(r.get("거래처", "") or "").strip()
        if not hcp:
            hcp = str(r.get("고객", "") or "").strip()
        if not item:
            item = str(r.get("품목", "") or "").strip()

        for emp in participants:
            if emp not in master_lookup:
                continue
            info = master_lookup[emp]
            events.append({
                "date": d,
                "type": "CALL",
                "empCode": emp,
                "empName": info.get("사원명", ""),
                "role": info.get("직책", ""),
                "region": info.get("권역명", ""),
                "team": info.get("부과명2", ""),
                "field": info.get("분야", ""),

                "account": acc,
                "person": hcp,
                "item": item,
            })

    return counts, events


