    <div class="card">
      <div class="cardTitle">상세</div>
      <div class="cardSub" id="mainSub">-</div>

      <div class="grid">
        <table id="tbl">
          <thead><tr id="theadRow"></tr></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="calendarView">
    <div class="card" style="max-width:none; margin:0 auto;">
      <div class="calTop">
        <div>
          <div class="cardTitle">달력</div>
          <div class="cardSub" id="calSub">-</div>
        </div>

        <div class="calNav">
          <select id="calYm"></select>
          <select id="calType">
            <option value="ALL">전체(CALL+SM)</option>
            <option value="CALL">CALL만</option>
            <option value="SM">SM만</option>
          </select>
        </div>
      </div>

      <div class="warn" id="calWarn" style="display:none;"></div>

      <div class="calWrap">
        <div class="calSide" id="calSide">
          <div class="sideTitle">품목별 요약</div>
          <div class="sideSub" id="calSumSub">-</div>
          <div class="sideTable" id="calSumTable"></div>
          <div class="sideNote">
            ※ 드래그로 폭 조절 가능 / 더블클릭 시 폭 초기화 / 새로고침해도 유지됩니다.
