    .num{ font-variant-numeric: tabular-nums; }

    /* ============================================================
       === [PATCH A] 상단 오른쪽 "선택 권역/팀/인원 평균" 카드 3개
       ============================================================ */
    .scopeKpis{
      margin-left:auto;
      display:flex;
      gap:8px;
      align-items:stretch;
      flex-wrap:wrap;
    }
    .scopeKpi{
      background:var(--panel2);
      border:1px solid var(--line);
      border-radius:12px;
      padding:8px 10px;
      min-width:210px;
    }
    .scopeLbl{ color:var(--muted); font-size:11px; font-weight:900; }
    .scopeVal{ margin-top:4px; font-weight:900; font-variant-numeric: tabular-nums; }
    .scopeSub{ margin-top:2px; color:var(--muted); font-size:11px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

    /* Calendar */
    #calendarView{ display:none; padding:16px; }
    .calTop{ display:flex; gap:10px; align-items:center; justify-content:space-between; flex-wrap:wrap; }
    .calNav{ display:flex; gap:8px; align-items:center; flex-wrap:wrap; }

    .calWrap{ display:flex; gap:12px; margin-top:12px; align-items:flex-start; }
    .calSide{
      background:var(--panel);
      border:1px solid var(--line);
      border-radius:14px;
      padding:12px;

      width:360px;
      min-width:260px;
      max-width:780px;

      resize:horizontal;
      overflow:auto;

      position:sticky;
      top:110px;
      max-height: calc(100vh - 140px);
    }
    .calSide::after{
      content:"↔";
      position:absolute;
      top:50%;
      right:6px;
      transform:translateY(-50%);
      color:var(--muted);
      font-weight:900;
      font-size:12px;
      pointer-events:none;
      opacity:.7;
    }
    .calMain{ flex:1; min-width:0; }

    .sideTitle{ font-weight:900; }
    .sideSub{ color:var(--muted); font-size:12px; margin-top:4px; }

    .sideTable{
      margin-top:10px;
      border:1px solid var(--line);
      border-radius:12px;
      overflow:auto;
    }
    .sideTable table{
      width:100%;
      border-collapse:collapse;
      table-layout:fixed;
      min-width:0;
    }
    .sideTable th, .sideTable td{
      padding:8px 8px;
      border-bottom:1px solid var(--line);
      text-align:right;
      font-size:12px;
      white-space:nowrap;
    }
    .sideTable th:first-child, .sideTable td:first-child{ text-align:left; }
    .sideTable thead th{ background:var(--panel2); position:sticky; top:0; z-index:2; }
    .sideTable td:first-child{
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .sideNote{ color:var(--muted); font-size:11px; margin-top:8px; }

    .calGrid{ display:grid; grid-template-columns: repeat(5, 1fr); gap:10px; }
    .calDow{ text-align:center; color:var(--muted); font-weight:900; padding:6px 0; }

    .calCell{
      background:var(--panel);
      border:1px solid var(--line);
      border-radius:12px;
      padding:10px;
      min-height:480px;
      display:flex;
      flex-direction:column;
      gap:6px;
      overflow:hidden;
    }
    .calDayLine{ display:flex; align-items:center; justify-content:space-between; }
    .calDay{ font-weight:900; }
    .calCnt{ font-size:12px; color:var(--muted); }
    .chip{
      display:inline-block; background:var(--chip); border:1px solid var(--line);
      border-radius:999px; padding:2px 8px; font-size:11px; margin-left:6px;
    }
    .evtBox{ overflow:auto; padding-right:4px; flex: 1; }
    .evtMini{
      font-size:12px; line-height:1.35;
      padding:4px 0; border-bottom:1px dashed rgba(0,0,0,.08);
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
    }
    .evtMini:last-child{ border-bottom:none; }
    .evtMini .t{ color:var(--muted); margin-right:6px; font-weight:900; }

    /* ============================================================
       === [PATCH B] SM 하이라이트(연하게) - 달력 리스트
       ============================================================ */
    .evtMini.sm{
      background: rgba(37,99,235,.07);
      border-radius: 8px;
      padding: 4px 6px;
    }

    .moreBtn{
      margin-top:6px; border:1px solid var(--line); background:transparent;
      border-radius:10px; padding:8px 10px; cursor:pointer; font-weight:900;
    }
    .warn{
      margin-top:10px; padding:10px 12px;
      border-radius:12px; border:1px solid var(--line);
      background:var(--panel2); color:var(--muted); font-size:12px;
    }

    /* Modal */
    .modalBg{
      position:fixed; inset:0; background:rgba(15,23,42,.35);
      display:none; align-items:center; justify-content:center; z-index:999; padding:16px;
    }
    .modal{
      width:min(960px, 100%); max-height:80vh; overflow:auto;
      background:var(--panel); border:1px solid var(--line); border-radius:14px; padding:14px;
      box-shadow:0 10px 30px rgba(0,0,0,.15);
    }
    .modalTop{
      display:flex; align-items:center; justify-content:space-between; gap:10px;
      position:sticky; top:0; background:var(--panel);
      padding-bottom:10px; border-bottom:1px solid var(--line);
    }
    .modalTitle{ font-weight:900; }
    .modalClose{ border:1px solid var(--line); background:transparent; border-radius:10px; padding:8px 10px; cursor:pointer; font-weight:900; }
    .modalList{ display:grid; gap:8px; margin-top:12px; }
    .evtCard{ background:var(--panel2); border:1px solid var(--line); border-radius:12px; padding:10px; }
    .evtTitle{ font-weight:900; }
    .evtSub{ color:var(--muted); font-size:12px; margin-top:4px; }

    /* SM 카드도 연하게 */
    .evtCard.sm{
      border-color: rgba(37,99,235,.25);
      background: rgba(37,99,235,.06);
    }

    @media (max-width: 1200px){
      .calWrap{ flex-direction:column; }
      .calSide{
        width:100%;
        max-width:none;
        resize:vertical;
        position:relative;
        top:auto;
        max-height:none;
      }
      .calSide::after{ content:"↕"; top:auto; bottom:6px; right:10px; transform:none; }
      .scopeKpis{ width:100%; margin-left:0; }
      .scopeKpi{ flex:1; min-width:220px; }
    }
    @media (max-width: 1100px){
      .wrap{ grid-template-columns: 1fr; }
      input{ width:200px; }
      table{ min-width:1080px; }
      .calGrid{ grid-template-columns: repeat(2, 1fr); }
      .calCell{ min-height:360px; }
    }
  </style>
</head>

<body>
  <div class="topbar">
    <div class="topRow">
      <div class="titleTop">월간 리포트</div>
      <div class="subTop" id="topSub">-</div>
      <div class="spacer"></div>
      <button class="btn ghost" id="calBtn">달력</button>
      <button class="btn ghost" id="backBtn" style="display:none;">리포트</button>
    </div>

    <div class="filterRow">
      <select id="region"></select>
      <select id="team"></select>
      <select id="emp"></select>
      <select id="field"></select>
      <input id="search" placeholder="사원명/사번/권역/팀/분야/이벤트 검색" />

      <div class="scopeKpis">
        <div class="scopeKpi">
          <div class="scopeLbl">선택 권역 평균 (콜/중식/석식)</div>
          <div class="scopeVal" id="sk_region">-</div>
          <div class="scopeSub" id="sk_region_sub">-</div>
        </div>
        <div class="scopeKpi">
          <div class="scopeLbl">선택 팀 평균 (콜/중식/석식)</div>
          <div class="scopeVal" id="sk_team">-</div>
          <div class="scopeSub" id="sk_team_sub">-</div>
        </div>
        <div class="scopeKpi">
          <div class="scopeLbl">선택 인원 평균 (콜/중식/석식)</div>
          <div class="scopeVal" id="sk_emp">-</div>
          <div class="scopeSub" id="sk_emp_sub">-</div>
        </div>
      </div>
    </div>
  </div>

  <div class="wrap" id="reportView">
    <div class="card">
      <div class="cardTitle">요약</div>
      <div class="cardSub" id="leftSub">-</div>

      <div class="tabs">
        <button class="tab active" data-tab="03팀원">03팀원</button>
        <button class="tab" data-tab="02팀장">02팀장</button>
      </div>

      <div style="display:flex; gap:10px; align-items:center; margin-top:10px; flex-wrap:wrap;">
        <div class="cardSub">요약 월 선택</div>
        <select id="kpiYm"></select>
      </div>

      <div class="kpi">
        <div class="item"><div class="label" id="kpi_lbl_all">-</div><div class="value" id="kpi_all">-</div></div>
        <div class="item"><div class="label">종병분야 평균 (콜/중식/석식)</div><div class="value" id="kpi_gh">-</div></div>
        <div class="item"><div class="label">병원분야 평균 (콜/중식/석식)</div><div class="value" id="kpi_cl">-</div></div>
        <div class="item"><div class="label">성장 평균 (콜/중식/석식)</div><div class="value" id="kpi_gr">-</div></div>
        <div class="item"><div class="label">선택 권역 평균 (콜/중식/석식)</div><div class="value" id="kpi_region">-</div></div>
        <div class="item"><div class="label">선택 부과 평균 (콜/중식/석식)</div><div class="value" id="kpi_team">-</div></div>
      </div>
